# Cornerstone MCP Server Configuration

# Required: Your Cornerstone API URL
CORNERSTONE_URL=https://your-cornerstone-instance.run.app

# Required: Your API key (get this from your Cornerstone admin)
CORNERSTONE_API_KEY=

# Optional: Default workspace (if not set, you'll choose on first use)
CORNERSTONE_NAMESPACE=default

# Optional: Agent identifier (defaults to "openclaw")
CORNERSTONE_AGENT_ID=openclaw

# OAuth (required for HTTP transport / Claude Desktop support)
# Secret for signing JWT tokens — generate with: python -c "import secrets; print(secrets.token_hex(32))"
OAUTH_JWT_SECRET=
# Public URL of this MCP server (auto-set on Cloud Run)
MCP_PUBLIC_URL=https://cornerstone-mcp-34862349933.europe-west2.run.app
